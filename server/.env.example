# =============================================================================
# LynkWell API — copy to .env and fill every required value:
#   cp .env.example .env
# Never commit `.env` (listed in server/.gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Google Gemini (POST /api/v1/ai/complete)
#
# A) Google AI Studio — GEMINI_API_KEY must start with AIza (https://aistudio.google.com/app/apikey)
#
# B) GCP / Vertex (use if you only have GCP creds — an "AQ…" string is NOT a Studio key)
#    Enable Vertex AI API; service account → role "Vertex AI User"; Keys → JSON.
#    GEMINI_API_KEY can stay empty. Auto-selects Vertex when GCP_PROJECT_ID + JSON exist.
#
#    GCP_PROJECT_ID=
#    GCP_LOCATION=us-central1
#    GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#    # GCP_SERVICE_ACCOUNT_JSON_B64=   # base64(JSON) — easier on Vercel
#    # GEMINI_PROVIDER=vertex          # optional; forces Vertex
#    # GEMINI_MODEL_ID=                # optional; Vertex default gemini-2.0-flash-001 if unset
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_PROVIDER=
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GCP_SERVICE_ACCOUNT_JSON=
# GCP_SERVICE_ACCOUNT_JSON_B64=
GEMINI_MODEL_ID=

# -----------------------------------------------------------------------------
# JWT (required; min 16 chars) — openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=

# -----------------------------------------------------------------------------
# Extension activation — at least one of: codes list OR 16+ char extension secret
# Comma-separated codes must include what the extension sends (see extension/lib/reach-api-default.js).
# -----------------------------------------------------------------------------
REACHAI_ACTIVATION_CODES=LINKWELL-CHROME
REACHAI_EXTENSION_SECRET=

# -----------------------------------------------------------------------------
# HTTP
# -----------------------------------------------------------------------------
PORT=3847
BIND_HOST=127.0.0.1

# -----------------------------------------------------------------------------
# Public API origin (no path) — used to build LinkedIn redirect for extension-flow login
# On Vercel: set to your deployment URL, e.g. https://your-api.vercel.app (also in Vercel → Settings → Environment Variables)
# -----------------------------------------------------------------------------
REACHAI_PUBLIC_URL=http://127.0.0.1:3847
# Optional full callback URL (overrides REACHAI_PUBLIC_URL + default path)
# LINKEDIN_EXT_FLOW_REDIRECT_URI=

# -----------------------------------------------------------------------------
# LinkedIn OAuth — Primary Client Secret from LinkedIn app → Auth (never in extension)
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Optional: exact chrome.identity redirect for legacy extension-only LinkedIn flow
# LINKEDIN_REDIRECT_URI=
